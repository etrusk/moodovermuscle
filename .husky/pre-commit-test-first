#!/bin/bash
# Enforce test-first: implementation files require corresponding test files

echo "🔍 Checking test-first compliance..."

# Get staged implementation files
IMPL_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "^(app|components|lib)/.*\.(ts|tsx)$" | grep -v "\.test\." | grep -v "\.config\." | grep -v "\.mock\." | grep -v "^lib/generated/")

if [ -z "$IMPL_FILES" ]; then
  echo "✅ No implementation files changed"
  exit 0
fi

# Check each implementation file has corresponding test
MISSING_TESTS=""
for IMPL_FILE in $IMPL_FILES; do
  BASE_NAME=$(basename "$IMPL_FILE" | sed -E 's/\.(ts|tsx)$//')
  DIR_NAME=$(dirname "$IMPL_FILE")
  
  # Try multiple test file locations
  TEST_PATTERNS=(
    "__tests__/${DIR_NAME}/${BASE_NAME}.test.tsx"
    "__tests__/${DIR_NAME}/${BASE_NAME}.test.ts"
    "${DIR_NAME}/${BASE_NAME}.test.tsx"
    "${DIR_NAME}/${BASE_NAME}.test.ts"
  )
  
  FOUND=false
  for TEST_PATTERN in "${TEST_PATTERNS[@]}"; do
    if [ -f "$TEST_PATTERN" ]; then
      FOUND=true
      break
    fi
  done
  
  if [ "$FOUND" = false ]; then
    MISSING_TESTS="${MISSING_TESTS}\n  ❌ ${IMPL_FILE}"
  fi
done

if [ -n "$MISSING_TESTS" ]; then
  echo ""
  echo "❌ TEST-FIRST VIOLATION"
  echo ""
  echo "Implementation files require corresponding test files:"
  echo -e "$MISSING_TESTS"
  echo ""
  exit 1
fi

echo "✅ All implementation files have tests"
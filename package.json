{
  "name": "moodovermuscle",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/etrusk/moodovermuscle.git"
  },
  "homepage": "https://moodovermuscle.com.au",
  "scripts": {
    "build": "prisma generate && next build",
    "dev": "next dev",
    "dev:start": "docker-compose up -d && npx prisma migrate deploy && npm run dev",
    "lint": "next lint",
    "start": "next start",
    "db:setup": "npx prisma generate && npx prisma migrate deploy && npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset --force",
    "db:backup": "chmod +x scripts/backup-database.sh && scripts/backup-database.sh",
    "db:restore": "chmod +x scripts/restore-database.sh && scripts/restore-database.sh",
    "db:test-connection": "node scripts/test-db-connection.js",
    "setup:verify": "node scripts/verify-setup.js",
    "type-check": "tsc --noEmit",
    "verify-deployment": "echo 'Verifying deployment configuration'",
    "verify-domain": "node scripts/verify-domain.js",
    "build-validate": "node scripts/build-validation.js",
    "health-check": "node scripts/health-check.js",
    "test-errors": "node scripts/test-error-scenarios.js",
    "pre-deploy": "pnpm run type-check && pnpm run build-validate && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:ci": "vitest run --coverage",
    "test:critical": "vitest run --config=vitest.config.critical.ts",
    "test:critical:ci": "vitest run --config=vitest.config.critical.ts --coverage",
    "test:quality": "node scripts/test-quality-check.js",
    "test:integration": "vitest run --grep integration",
    "test:integration:ci": "vitest run --grep integration --passWithNoTests",
    "test:full": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:accessibility:unit": "vitest --config=vitest.config.accessibility.ts",
    "test:accessibility:e2e": "playwright test --config=playwright.config.accessibility.ts",
    "test:accessibility:all": "pnpm run test:accessibility:unit && pnpm run test:accessibility:e2e",
    "accessibility:ci": "pnpm run test:accessibility:unit --ci && pnpm run test:accessibility:e2e --config=playwright.config.accessibility.ts --retries=2",
    "accessibility:regression-check": "bash scripts/accessibility-regression-check.sh",
    "accessibility:validate": "bash scripts/validate-accessibility-compliance.sh",
    "accessibility:report": "playwright show-report --reporter=html",
    "security:scan": "pnpm audit --audit-level moderate --production",
    "security:semgrep": "if command -v semgrep >/dev/null 2>&1; then semgrep --config=auto --quiet --error --timeout=60 .; else echo '⚠️  Semgrep not installed - skipping security scan. Install with: yay -S semgrep' && exit 0; fi",
    "build:verify": "pnpm run type-check && ADMIN_JWT_SECRET=build-time-secret-for-verification next build >/dev/null 2>&1",
    "complexity-check": "node scripts/complexity-check.js",
    "duplication-check": "jscpd --config .jscpd.json",
    "quality:gates": "pnpm run lint && pnpm run type-check && pnpm run test:critical && pnpm run security:scan && pnpm run security:semgrep && pnpm run build:verify",
    "deploy:verify": "pnpm run quality:gates",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "quality-gates": "node scripts/quality-gates.js",
    "quality-gates:critical": "node scripts/quality-gates.js",
    "memory:update": "node scripts/memory-updater.js update",
    "deployment:gates": "pnpm run quality-gates && pnpm run memory:update",
    "deps:check": "node scripts/check-dependencies.js",
    "deps:update": "pnpm update --latest -r",
    "deps:audit": "pnpm audit --audit-level moderate"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.12.0",
    "@radix-ui/react-accordion": "latest",
    "@radix-ui/react-alert-dialog": "latest",
    "@radix-ui/react-aspect-ratio": "latest",
    "@radix-ui/react-avatar": "latest",
    "@radix-ui/react-checkbox": "latest",
    "@radix-ui/react-collapsible": "latest",
    "@radix-ui/react-context-menu": "latest",
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-dropdown-menu": "latest",
    "@radix-ui/react-hover-card": "latest",
    "@radix-ui/react-label": "latest",
    "@radix-ui/react-menubar": "latest",
    "@radix-ui/react-navigation-menu": "latest",
    "@radix-ui/react-popover": "latest",
    "@radix-ui/react-progress": "latest",
    "@radix-ui/react-radio-group": "latest",
    "@radix-ui/react-scroll-area": "latest",
    "@radix-ui/react-select": "latest",
    "@radix-ui/react-separator": "latest",
    "@radix-ui/react-slider": "latest",
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-switch": "latest",
    "@radix-ui/react-tabs": "latest",
    "@radix-ui/react-toast": "latest",
    "@radix-ui/react-toggle": "latest",
    "@radix-ui/react-toggle-group": "latest",
    "@radix-ui/react-tooltip": "latest",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^6.4.17",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "latest",
    "date-fns": "4.1.0",
    "embla-carousel-react": "latest",
    "input-otp": "latest",
    "jose": "^6.0.12",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.454.0",
    "next": "15.4.7",
    "next-themes": "latest",
    "nodemailer": "^7.0.9",
    "prisma": "^6.12.0",
    "react": "^19",
    "react-day-picker": "latest",
    "react-dom": "^19",
    "react-hook-form": "latest",
    "react-resizable-panels": "latest",
    "recharts": "latest",
    "sonner": "latest",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "latest",
    "whatwg-fetch": "^3.6.20",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@faker-js/faker": "^8.4.1",
    "@mswjs/interceptors": "^0.39.4",
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/typescript-estree": "^8.46.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "dotenv": "^17.2.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.4.7",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.0",
    "jest-axe": "^10.0.0",
    "jscpd": "^4.0.5",
    "jsdom": "^27.0.0",
    "lint-staged": "^15.2.0",
    "msw": "^2.10.4",
    "postcss": "^8.5",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vite": "^7.1.9",
    "vitest": "^3.2.4"
  }
}

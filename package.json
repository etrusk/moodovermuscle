{
  "name": "moodovermuscle",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/etrusk/moodovermuscle.git"
  },
  "homepage": "https://moodovermuscle.com.au",
  "scripts": {
    "build": "prisma generate && next build",
    "build:deploy": "prisma migrate deploy && prisma generate && next build",
    "dev": "next dev",
    "dev:start": "docker-compose up -d && npx prisma migrate deploy && npm run dev",
    "lint": "eslint app components lib middleware.ts",
    "start": "next start",
    "db:setup": "npx prisma generate && npx prisma migrate deploy && npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset --force",
    "db:backup": "chmod +x scripts/backup-database.sh && scripts/backup-database.sh",
    "db:restore": "chmod +x scripts/restore-database.sh && scripts/restore-database.sh",
    "type-check": "tsc --noEmit",
    "verify-deployment": "echo 'Verifying deployment configuration'",
    "pre-deploy": "pnpm run type-check && pnpm run build-validate && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:ci": "vitest run --coverage",
    "test:critical": "vitest run --config=vitest.config.critical.ts",
    "test:critical:ci": "vitest run --config=vitest.config.critical.ts --coverage --reporter=verbose",
    "test:quality": "node scripts/test-quality-check.js",
    "test:integration": "vitest run --grep integration",
    "test:integration:ci": "vitest run --passWithNoTests __tests__/integration/**/*.test.{ts,tsx}",
    "test:full": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:accessibility:unit": "vitest --config=vitest.config.accessibility.ts",
    "test:accessibility:e2e": "playwright test --config=playwright.config.accessibility.ts",
    "test:accessibility:all": "pnpm run test:accessibility:unit && pnpm run test:accessibility:e2e",
    "accessibility:regression-check": "bash scripts/accessibility-regression-check.sh",
    "accessibility:validate": "bash scripts/validate-accessibility-compliance.sh",
    "accessibility:report": "playwright show-report --reporter=html",
    "accessibility:ci": "playwright test -c playwright.config.accessibility.ts",
    "security:scan": "pnpm audit --audit-level moderate --production",
    "security:semgrep": "if semgrep --version >/dev/null 2>&1; then semgrep --config=auto --quiet --error --timeout=60 .; else echo '⚠️  Semgrep not available - skipping. Install with: pipx install semgrep' && exit 0; fi",
    "build:verify": "pnpm run type-check && ADMIN_JWT_SECRET=build-time-secret-for-verification next build >/dev/null 2>&1",
    "duplication-check": "jscpd --config .jscpd.json",
    "quality:gates": "pnpm run lint && pnpm run type-check && pnpm run test:critical && pnpm run security:scan && pnpm run security:semgrep && pnpm run build:verify",
    "deploy:verify": "pnpm run quality:gates",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "lint-staged": "lint-staged",
    "deps:update": "pnpm update --latest -r",
    "deps:audit": "pnpm audit --audit-level moderate"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-hover-card": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.454.0",
    "next": "^16.2.10",
    "nodemailer": "^9.0.3",
    "react": "^19.2.7",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "overrides": {
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "postcss@<8.5.10": ">=8.5.10",
      "@babel/core@<7.29.6": ">=7.29.6 <8"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@typescript-eslint/typescript-estree": "^8.63.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jscpd": "^4.2.5",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.5.2",
    "msw": "^2.15.0",
    "postcss": "^8.5.17",
    "prettier": "^3.9.5",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}

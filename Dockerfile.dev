# Development Dockerfile for MoodOverMuscle Next.js application
# This creates a container optimized for local development with hot-reload
# Note: This is for local development only. Production deployment uses Vercel.

FROM node:18-alpine

# Set working directory
WORKDIR /app

# Install pnpm globally (as specified in tech requirements)
RUN npm install -g pnpm

# Create non-root user for security
RUN addgroup -g 1001 -S nodejs
RUN adduser -S nextjs -u 1001

# Copy package files first for better Docker layer caching
COPY package.json pnpm-lock.yaml* ./

# Install dependencies
RUN pnpm install

# Copy source code
COPY . .

# Change ownership to non-root user
RUN chown -R nextjs:nodejs /app
USER nextjs

# Expose port 3000 (Next.js development server default)
EXPOSE 3000

# Set environment variables for development
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1

# Start development server with hot-reload
CMD ["pnpm", "dev"]
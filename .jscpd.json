{
  "threshold": 3,
  "reporters": ["console"],
  "ignore": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "node_modules/**",
    ".next/**",
    "build/**",
    "dist/**",
    ".docker/**",
    "archive-backups/**",
    "lib/generated/**",
    "vitest.setup.ts",
    "vitest.setup.node.ts",
    "scripts/**"
  ],
  "format": ["typescript", "javascript"],
  "minLines": 5,
  "minTokens": 50,
  "exitCode": 1,
  "skipEmpty": true
}
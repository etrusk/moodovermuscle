
#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Phase 3: Quality & Deployment Integration
echo "🚀 Running deployment gates..."

# Circuit breaker verification - blocks commit on quality failures
echo "🔥 Running circuit breaker verification..."
pnpm run circuit-breakers:verify

# Only proceed if circuit breakers pass
if [ $? -ne 0 ]; then
  echo "🚨 Circuit breakers triggered - commit blocked"
  echo "Run 'pnpm run circuit-breakers:status' for guidance"
  exit 1
fi

# Check for functionality changes first
if ! pnpm run workflow:detect; then
  echo "⚠️  Functionality changes detected - preview workflow required"
  echo "Run 'pnpm run workflow:create-preview' before committing"
  exit 1
fi

# Run critical quality gates
pnpm run quality-gates:critical

# Update institutional memory
pnpm run memory:update

# Run traditional pre-commit tasks
echo "📝 Running lint-staged (ESLint + Prettier)..."
pnpm exec lint-staged

echo "🔧 Running TypeScript type check..."
pnpm run type-check

echo "📚 Checking documentation staleness..."
pnpm run docs:staleness

echo "✅ All deployment gates passed!"
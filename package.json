{
  "name": "moodovermuscle",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/etrusk/moodovermuscle.git"
  },
  "homepage": "https://moodovermuscle.com.au",
  "scripts": {
    "build": "prisma generate && next build",
    "dev": "next dev",
    "lint": "next lint",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "verify-deployment": "echo 'Verifying deployment configuration'",
    "verify-domain": "node scripts/verify-domain.js",
    "build-validate": "node scripts/build-validation.js",
    "health-check": "node scripts/health-check.js",
    "test-errors": "node scripts/test-error-scenarios.js",
    "pre-deploy": "pnpm run type-check && pnpm run build-validate && pnpm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage",
    "test:critical": "jest --config=jest.config.critical.ts",
    "test:critical:ci": "jest --config=jest.config.critical.ts --ci --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:integration:ci": "jest --testPathPattern=integration --ci --passWithNoTests",
    "test:full": "jest --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:accessibility:unit": "jest --config=jest.config.accessibility.ts",
    "test:accessibility:e2e": "playwright test --config=playwright.config.accessibility.ts",
    "test:accessibility:all": "pnpm run test:accessibility:unit && pnpm run test:accessibility:e2e && bash scripts/lighthouse-accessibility-gates.sh",
    "accessibility:ci": "pnpm run test:accessibility:unit --ci && pnpm run test:accessibility:e2e --config=playwright.config.accessibility.ts --retries=2 && bash scripts/lighthouse-accessibility-gates.sh",
    "accessibility:regression-check": "bash scripts/accessibility-regression-check.sh",
    "accessibility:validate": "bash scripts/validate-accessibility-compliance.sh",
    "accessibility:report": "playwright show-report --reporter=html",
    "lighthouse": "npm run lighthouse:clean && lhci autorun && npm run lighthouse:cleanup",
    "lighthouse:ci": "lhci autorun --config=lighthouserc.js",
    "lighthouse:serve": "lhci server",
    "lighthouse:local": "npm run lighthouse:clean && lhci autorun --config=lighthouserc.js && npm run lighthouse:cleanup",
    "lighthouse:clean": "./scripts/lighthouse-cleanup.sh",
    "lighthouse:cleanup": "./scripts/lighthouse-cleanup.sh",
    "lighthouse:test": "npm run lighthouse:clean && npm run build && npm run lighthouse:local && npm run lighthouse:validate",
    "lighthouse:validate": "./scripts/lighthouse-quality-gates.sh",
    "lighthouse:check": "./scripts/lighthouse-quality-gates.sh",
    "security:scan": "pnpm audit --audit-level moderate --production",
    "build:verify": "pnpm run type-check && next build >/dev/null 2>&1",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.12.0",
    "@radix-ui/react-accordion": "latest",
    "@radix-ui/react-alert-dialog": "latest",
    "@radix-ui/react-aspect-ratio": "latest",
    "@radix-ui/react-avatar": "latest",
    "@radix-ui/react-checkbox": "latest",
    "@radix-ui/react-collapsible": "latest",
    "@radix-ui/react-context-menu": "latest",
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-dropdown-menu": "latest",
    "@radix-ui/react-hover-card": "latest",
    "@radix-ui/react-label": "latest",
    "@radix-ui/react-menubar": "latest",
    "@radix-ui/react-navigation-menu": "latest",
    "@radix-ui/react-popover": "latest",
    "@radix-ui/react-progress": "latest",
    "@radix-ui/react-radio-group": "latest",
    "@radix-ui/react-scroll-area": "latest",
    "@radix-ui/react-select": "latest",
    "@radix-ui/react-separator": "latest",
    "@radix-ui/react-slider": "latest",
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-switch": "latest",
    "@radix-ui/react-tabs": "latest",
    "@radix-ui/react-toast": "latest",
    "@radix-ui/react-toggle": "latest",
    "@radix-ui/react-toggle-group": "latest",
    "@radix-ui/react-tooltip": "latest",
    "@types/nodemailer": "^6.4.17",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "latest",
    "date-fns": "4.1.0",
    "embla-carousel-react": "latest",
    "input-otp": "latest",
    "lucide-react": "^0.454.0",
    "next": "15.2.4",
    "next-themes": "latest",
    "nodemailer": "^7.0.5",
    "prisma": "^6.12.0",
    "react": "^19",
    "react-day-picker": "latest",
    "react-dom": "^19",
    "react-hook-form": "latest",
    "react-resizable-panels": "latest",
    "recharts": "latest",
    "sonner": "latest",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "latest",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@faker-js/faker": "^8.4.1",
    "@lhci/cli": "^0.13.0",
    "@mswjs/interceptors": "^0.39.4",
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^29.5.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "dotenv": "^17.2.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.2.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "lint-staged": "^15.2.0",
    "msw": "^2.10.4",
    "postcss": "^8.5",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}

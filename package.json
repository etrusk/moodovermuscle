{
  "name": "moodovermuscle",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/etrusk/moodovermuscle.git"
  },
  "homepage": "https://moodovermuscle.com.au",
  "scripts": {
    "build": "prisma generate && next build",
    "dev": "next dev",
    "dev:start": "docker-compose up -d && npx prisma migrate deploy && npm run dev",
    "lint": "next lint",
    "start": "next start",
    "db:setup": "npx prisma generate && npx prisma migrate deploy && npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset --force",
    "db:backup": "chmod +x scripts/backup-database.sh && scripts/backup-database.sh",
    "db:restore": "chmod +x scripts/restore-database.sh && scripts/restore-database.sh",
    "type-check": "tsc --noEmit",
    "verify-deployment": "echo 'Verifying deployment configuration'",
    "pre-deploy": "pnpm run type-check && pnpm run build-validate && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:ci": "vitest run --coverage",
    "test:critical": "vitest run --config=vitest.config.critical.ts",
    "test:critical:ci": "vitest run --coverage --reporter=verbose",
    "test:quality": "node scripts/test-quality-check.js",
    "test:integration": "vitest run --grep integration",
    "test:integration:ci": "vitest run --include **/*.integration.test.{ts,tsx} --passWithNoTests",
    "test:full": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:accessibility:unit": "vitest --config=vitest.config.accessibility.ts",
    "test:accessibility:e2e": "playwright test --config=playwright.config.accessibility.ts",
    "test:accessibility:all": "pnpm run test:accessibility:unit && pnpm run test:accessibility:e2e",
    "accessibility:regression-check": "bash scripts/accessibility-regression-check.sh",
    "accessibility:validate": "bash scripts/validate-accessibility-compliance.sh",
    "accessibility:report": "playwright show-report --reporter=html",
    "accessibility:ci": "playwright test -c playwright.config.accessibility.ts",
    "security:scan": "pnpm audit --audit-level moderate --production",
    "security:semgrep": "if command -v semgrep >/dev/null 2>&1; then semgrep --config=auto --quiet --error --timeout=60 .; else echo '⚠️  Semgrep not installed - skipping security scan. Install with: yay -S semgrep' && exit 0; fi",
    "build:verify": "pnpm run type-check && ADMIN_JWT_SECRET=build-time-secret-for-verification next build >/dev/null 2>&1",
    "duplication-check": "jscpd --config .jscpd.json",
    "quality:gates": "pnpm run lint && pnpm run type-check && pnpm run test:critical && pnpm run security:scan && pnpm run security:semgrep && pnpm run build:verify",
    "deploy:verify": "pnpm run quality:gates",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "deps:update": "pnpm update --latest -r",
    "deps:audit": "pnpm audit --audit-level moderate"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^6.17.1",
    "@radix-ui/react-accordion": "latest",
    "@radix-ui/react-alert-dialog": "latest",
    "@radix-ui/react-avatar": "latest",
    "@radix-ui/react-checkbox": "latest",
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-dropdown-menu": "latest",
    "@radix-ui/react-hover-card": "latest",
    "@radix-ui/react-label": "latest",
    "@radix-ui/react-popover": "latest",
    "@radix-ui/react-select": "latest",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-switch": "latest",
    "@radix-ui/react-toast": "latest",
    "@radix-ui/react-toggle": "latest",
    "@radix-ui/react-toggle-group": "latest",
    "@radix-ui/react-tooltip": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^6.4.20",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "4.1.0",
    "jose": "^6.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.454.0",
    "next": "15.4.7",
    "nodemailer": "^7.0.9",
    "prisma": "^6.17.1",
    "react": "^19.2.0",
    "react-day-picker": "latest",
    "react-dom": "^19.2.0",
    "react-hook-form": "latest",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@faker-js/faker": "^8.4.1",
    "@mswjs/interceptors": "^0.39.8",
    "@playwright/test": "^1.56.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.18.10",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@typescript-eslint/typescript-estree": "^8.46.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.4.7",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jscpd": "^4.0.5",
    "jsdom": "^27.0.0",
    "lint-staged": "^15.5.2",
    "msw": "^2.11.5",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.18",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^3.2.4"
  }
}

{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Australia/Sydney",
  "schedule": [
    "after 9am on Monday"
  ],
  "prCreation": "immediate",
  "prConcurrentLimit": 10,
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "platformAutomerge": true,
  "ignoreTests": false,
  "packageRules": [
    {
      "description": "Auto-merge non-breaking npm/pnpm updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "non-breaking dependencies",
      "automerge": true,
      "prPriority": 10,
      "labels": ["dependencies", "automated"],
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    },
    {
      "description": "Major npm/pnpm updates require manual review (one PR per package)",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "prPriority": 5,
      "labels": ["dependencies", "automated", "requires-attention", "major-update"],
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    },
    {
      "description": "Auto-merge GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "prPriority": 8,
      "labels": ["ci", "automated"],
      "semanticCommitType": "ci",
      "semanticCommitScope": "actions"
    },
    {
      "description": "Major GitHub Actions updates require manual review",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "prPriority": 3,
      "labels": ["ci", "automated", "requires-attention", "major-update"],
      "semanticCommitType": "ci",
      "semanticCommitScope": "actions"
    }
  ],
  "prNotPendingHours": 0,
  "stabilityDays": 0,
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "🤖 Renovate Dashboard",
  "dependencyDashboardLabels": ["dependencies"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 10am on Monday"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "requires-attention"],
    "automerge": false
  },
  "rebaseWhen": "conflicted",
  "configMigration": true
}